# ╔══════════════════════════════════════════════════════════════════╗
# ║         MediaPlayer AI — Environment Variables                   ║
# ║  Copy this file to .env and fill in your keys.                   ║
# ║  Variables starting with EXPO_PUBLIC_ are exposed to the client. ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Ads ─────────────────────────────────────────────────────────────────────
# Master switch (false = disable all ads, useful in CI / unit tests)
EXPO_PUBLIC_ADS_ENABLED=true

# Use Google's test ad unit IDs (true = dev / false = production)
EXPO_PUBLIC_ADS_TEST_MODE=false

# Individual ad type toggles
EXPO_PUBLIC_ADS_APP_OPEN=true
EXPO_PUBLIC_ADS_BANNER=true
EXPO_PUBLIC_ADS_NATIVE=true
EXPO_PUBLIC_ADS_INTERSTITIAL=true

# ─── AdMob Unit IDs (Android) ────────────────────────────────────────────────
EXPO_PUBLIC_ADMOB_ANDROID_APP_OPEN=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_ANDROID_BANNER=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_ANDROID_NATIVE=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# ─── AdMob Unit IDs (iOS) ────────────────────────────────────────────────────
EXPO_PUBLIC_ADMOB_IOS_APP_OPEN=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_IOS_BANNER=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_IOS_NATIVE=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# ─── Subscription (RevenueCat) ───────────────────────────────────────────────
EXPO_PUBLIC_SUB_ENABLED=true
EXPO_PUBLIC_REVENUECAT_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Network Streaming ───────────────────────────────────────────────────────
EXPO_PUBLIC_SMB_ENABLED=true
EXPO_PUBLIC_FTP_ENABLED=true
EXPO_PUBLIC_WEBDAV_ENABLED=true

# ─── Google Drive OAuth ──────────────────────────────────────────────────────
EXPO_PUBLIC_GDRIVE_ENABLED=true
EXPO_PUBLIC_GDRIVE_CLIENT_ID=XXXXXXXX.apps.googleusercontent.com
EXPO_PUBLIC_GDRIVE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXX

# ─── Dropbox OAuth ───────────────────────────────────────────────────────────
EXPO_PUBLIC_DROPBOX_ENABLED=true
EXPO_PUBLIC_DROPBOX_APP_KEY=XXXXXXXXXXXXXXXX

# ─── TMDB (Movie Metadata) ───────────────────────────────────────────────────
EXPO_PUBLIC_TMDB_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_METADATA_AUTO_FETCH=true
