{
  "expo": {
    "name": "MediaPlayerAI",
    "slug": "mediaplayerai",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mediaplayerai.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Used for song recognition by humming",
        "NSAppleMusicUsageDescription": "Used to access your music library"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.mediaplayerai.app",
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-av",
      "expo-document-picker",
      [
        "expo-file-system",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ]
  }
}
